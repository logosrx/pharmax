{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Audit chain integrity: row throughput, verifier health, age of the latest signed Merkle manifest per tenant.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "audit_log rows per second (by tenant)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "showLegend": true,
          "placement": "right",
          "displayMode": "table",
          "calcs": ["mean", "max"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (organization_id) (rate(pharmax_audit_log_rows_total{deployment_environment=~\"$environment\"}[5m]))",
          "legendFormat": "{{ organization_id }}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Verifier success rate (last 1h)",
      "description": "Should be 100%. Any drop is a SEV1 compliance event — chain has been broken.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.999 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "value",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (sum(rate(pharmax_audit_verifier_failures_total{deployment_environment=~\"$environment\"}[1h])) / clamp_min(sum(rate(pharmax_audit_log_rows_total{deployment_environment=~\"$environment\"}[1h])), 1e-9))",
          "legendFormat": "verifier success"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Manifest age per tenant (hours)",
      "description": "time() - latest_signed_at. Threshold red at 26h to match alert AuditManifestStale.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 22 },
              { "color": "red", "value": 26 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "value_and_name",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(time() - max by (organization_id) (pharmax_audit_manifest_latest_signed_at_seconds{deployment_environment=~\"$environment\"})) / 3600",
          "legendFormat": "{{ organization_id }}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Verifier failures (per minute, by tenant)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "auto" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "showLegend": true,
          "placement": "right",
          "displayMode": "table",
          "calcs": ["sum"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (organization_id) (rate(pharmax_audit_verifier_failures_total{deployment_environment=~\"$environment\"}[5m]))",
          "legendFormat": "{{ organization_id }}"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Audit chain log events (Loki)",
      "description": "Tail of structured log lines matching the audit chain. Use to find the offending row id quickly when verifier fails.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"pharmacy-(web|worker|print-agent)\"} |= \"audit_chain\""
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["pharmax", "audit", "compliance"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(deployment_environment)",
        "query": {
          "qryType": 1,
          "query": "label_values(deployment_environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "options": [],
        "hide": 0
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(service_name)",
        "query": {
          "qryType": 1,
          "query": "label_values(service_name)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "options": [],
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Pharmax · Audit Chain",
  "uid": "pharmax-audit-chain",
  "version": 1,
  "weekStart": ""
}
