{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Billing pipeline health: invoice creation throughput, Stripe push success, refund issuance, aged-receivable trending.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Stripe push success ratio (15m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "value",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pharmax_billing_stripe_push_total{deployment_environment=~\"$environment\", outcome=\"success\"}[15m])) / clamp_min(sum(rate(pharmax_billing_stripe_push_total{deployment_environment=~\"$environment\"}[15m])), 1e-9)",
          "legendFormat": "success ratio"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Invoice lines per minute",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pharmax_billing_invoice_lines_created_total{deployment_environment=~\"$environment\"}[5m])) * 60",
          "legendFormat": "lines/min"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Refunds issued per hour",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value",
        "orientation": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pharmax_billing_refunds_issued_total{deployment_environment=~\"$environment\"}[1h])) * 3600",
          "legendFormat": "refunds/h"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Invoice lifecycle throughput (per minute)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "showLegend": true,
          "placement": "bottom",
          "displayMode": "table",
          "calcs": ["mean", "max"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pharmax_billing_invoice_lines_created_total{deployment_environment=~\"$environment\"}[5m]))",
          "legendFormat": "lines created/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(pharmax_billing_invoice_finalized_total{deployment_environment=~\"$environment\"}[5m]))",
          "legendFormat": "finalized/s"
        },
        {
          "refId": "C",
          "expr": "sum(rate(pharmax_billing_stripe_push_total{deployment_environment=~\"$environment\", outcome=\"success\"}[5m]))",
          "legendFormat": "pushed to stripe/s"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Stripe push outcomes (per second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "showLegend": true,
          "placement": "bottom",
          "displayMode": "table",
          "calcs": ["mean", "max"]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(pharmax_billing_stripe_push_total{deployment_environment=~\"$environment\"}[5m]))",
          "legendFormat": "{{ outcome }}"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Recent Stripe push failures (Loki)",
      "description": "Worker logs filtered to Stripe push failures. Use to find specific invoice ids that failed.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"pharmacy-worker\"} |= \"billing.invoice.finalized.v1\" |~ \"error|fail\""
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["pharmax", "billing"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(deployment_environment)",
        "query": {
          "qryType": 1,
          "query": "label_values(deployment_environment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "options": [],
        "hide": 0
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(service_name)",
        "query": {
          "qryType": 1,
          "query": "label_values(service_name)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "options": [],
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Pharmax · Billing",
  "uid": "pharmax-billing",
  "version": 1,
  "weekStart": ""
}
