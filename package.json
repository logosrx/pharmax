{
  "name": "pharmax",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter pharmacy-os dev",
    "worker:dev": "pnpm --filter pharmacy-worker dev",
    "worker:start": "pnpm --filter pharmacy-worker start",
    "print-agent:dev": "pnpm --filter pharmacy-print-agent dev",
    "print-agent:start": "pnpm --filter pharmacy-print-agent start",
    "build": "pnpm -r --if-present build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "pnpm --filter @pharmax/integration-tests test",
    "test:integration:watch": "pnpm --filter @pharmax/integration-tests test:watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && pnpm -r --if-present typecheck",
    "prisma:validate": "DATABASE_URL=\"postgresql://validate:validate@localhost:5432/validate\" DIRECT_URL=\"postgresql://validate:validate@localhost:5432/validate\" prisma validate --schema prisma/schema.prisma",
    "prisma:format": "DATABASE_URL=\"postgresql://validate:validate@localhost:5432/validate\" DIRECT_URL=\"postgresql://validate:validate@localhost:5432/validate\" prisma format --schema prisma/schema.prisma",
    "check:migrations": "tsx scripts/check-migration-rls.ts",
    "check:schema": "tsx scripts/check-prisma-schema.ts",
    "check:commands": "tsx scripts/check-command-files.ts",
    "check:kms-inventory": "tsx scripts/check-kms-inventory.ts",
    "events:validate": "tsx scripts/events/validate-registry.ts",
    "events:migrate-check": "tsx scripts/events/migrate-allowlist.ts",
    "verify": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm prisma:validate && pnpm check:migrations && pnpm check:schema && pnpm check:commands && pnpm check:kms-inventory && pnpm events:validate && pnpm events:migrate-check && pnpm test",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose stop postgres redis",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema prisma/schema.prisma --skip-seed",
    "db:seed": "tsx prisma/seed.ts",
    "bootstrap:org": "tsx scripts/bootstrap-org.ts",
    "resolve:emergency": "tsx scripts/resolve-emergency-bucket.ts",
    "verify:kms": "tsx scripts/security/verify-kms-keys.ts",
    "security:sign-merkle": "tsx scripts/security/sign-daily-merkle-root.ts",
    "security:verify-merkle": "tsx scripts/security/verify-merkle-manifest.ts",
    "security:verify-chain-all": "tsx scripts/security/verify-audit-chain-all-orgs.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "prepare": "husky",
    "postinstall": "pnpm db:generate",
    "status": "git status"
  },
  "devDependencies": {
    "@aws-sdk/client-kms": "^3.703.0",
    "@aws-sdk/client-s3": "^3.703.0",
    "@eslint/js": "^9.13.0",
    "@pharmax/audit": "workspace:*",
    "@pharmax/billing": "workspace:*",
    "@pharmax/command-bus": "workspace:*",
    "@pharmax/composition": "workspace:*",
    "@pharmax/crypto": "workspace:*",
    "@pharmax/database": "workspace:*",
    "@pharmax/documents": "workspace:*",
    "@pharmax/events": "workspace:*",
    "@pharmax/fill": "workspace:*",
    "@pharmax/integration-tests": "workspace:*",
    "@pharmax/notifications": "workspace:*",
    "@pharmax/orders": "workspace:*",
    "@pharmax/orgs": "workspace:*",
    "@pharmax/package-capture": "workspace:*",
    "@pharmax/patients": "workspace:*",
    "@pharmax/platform-core": "workspace:*",
    "@pharmax/providers": "workspace:*",
    "@pharmax/rbac": "workspace:*",
    "@pharmax/reporting": "workspace:*",
    "@pharmax/scan": "workspace:*",
    "@pharmax/security": "workspace:*",
    "@pharmax/shipping": "workspace:*",
    "@pharmax/sla": "workspace:*",
    "@pharmax/telemetry": "workspace:*",
    "@pharmax/tenancy": "workspace:*",
    "@pharmax/labels": "workspace:*",
    "@pharmax/verification": "workspace:*",
    "@pharmax/workflow": "workspace:*",
    "@prisma/client": "^5.22.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.0",
    "vitest": "^2.1.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
