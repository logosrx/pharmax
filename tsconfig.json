{
  "extends": "./tsconfig.base.json",
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "prisma/seed.ts",
    "scripts/**/*.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/.next",
    "**/build",
    "**/coverage",
    "**/generated/**"
  ]
}
