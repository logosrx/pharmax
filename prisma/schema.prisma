// Pharmax Prisma schema.
//
// Sections (top to bottom):
//   1. Generator + datasource
//   2. Enums
//   3. Tenancy core      (organization, site, clinic, team, bucket, workstation)
//   4. Identity / RBAC   (user, role, permission, role_permission, user_role)
//   5. Workflow policy   (workflow_policy)
//   6. Audit primitives  (command_log, order_event, audit_log,
//                         audit_chain_state, event_outbox, idempotency_key)
//   7. Billing           (stripe_customer, stripe_webhook_event, invoice,
//                         invoice_line)
//   8. Domain entities   (patient, provider, prescription, order, order_line)
//
// Migration status: applied (a) the baseline and (b) the RLS baseline
// + (c) the audit hash-chain + (d) the phase-2 patient/Rx/order
// schema. See `prisma/README.md`.
//
// Naming convention: snake_case tables (via `@@map`), camelCase column
// names (no field-level `@map`). This matches the existing billing models
// already merged. A future PR may globalize columns to snake_case; that
// will require a migration and is intentionally out of scope here.
//
// Tenancy invariant: every domain row carries `organizationId`. Rows that
// belong to a single clinic also carry `clinicId`. Repository base classes
// (added in `@pharmax/tenancy`) refuse to issue queries without a tenant
// context. See `.cursor/rules/02-security-compliance.mdc`.
//
// PHI invariant: patient-identifying data is confined to the section-8
// models (`patient`, `prescription`, `order`, `order_line`). PHI columns
// are envelope-encrypted JSON (suffix `Enc`) with AAD-bound bindings
// from `@pharmax/crypto`; searchable PHI is paired with HMAC blind-
// index columns (suffix `Bi`). All other sections MUST stay PHI-free.

// The client is emitted INTO the @pharmax/database package so consumers
// import from `@pharmax/database`, not from `@prisma/client` directly.
// The generated directory is gitignored and rebuilt on `pnpm install` and
// after every schema or migration change (`pnpm db:generate`).
generator client {
  provider        = "prisma-client-js"
  output          = "../packages/database/src/generated/client"
  previewFeatures = []
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================================================================
// 2. Enums
// ===========================================================================

