# =====================================================================
# Pharmax local environment template.
# Copy to .env (gitignored) and fill in any blank values.
# Never put real PHI, real customer keys, or production secrets here.
# =====================================================================

# ----- Application ---------------------------------------------------
NODE_ENV="development"
APP_NAME="Pharmax"
APP_URL="http://localhost:3000"
PORT="3000"
LOG_LEVEL="debug"

# ----- Database ------------------------------------------------------
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="pharmax"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pharmax"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pharmax"

# ----- Redis / Valkey ------------------------------------------------
REDIS_URL="redis://localhost:6379"

# ----- Object storage (MinIO in dev, S3 in prod) ---------------------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET_NAME="pharmax-dev"
S3_FORCE_PATH_STYLE="true"
S3_ACCESS_KEY_ID="pharmax_minio"
S3_SECRET_ACCESS_KEY="pharmax_minio_dev"
MINIO_ROOT_USER="pharmax_minio"
MINIO_ROOT_PASSWORD="pharmax_minio_dev"

# ----- Mail (Mailhog in dev) -----------------------------------------
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Pharmax <no-reply@pharmax.local>"

# ----- PgAdmin -------------------------------------------------------
PGADMIN_EMAIL="admin@pharmax.local"
PGADMIN_PASSWORD="pharmax_dev"

# ----- Sessions / Auth ----------------------------------------------
# Generate with: openssl rand -base64 48
SESSION_SECRET="replace-with-random-48-byte-base64-string"
JWT_SECRET="replace-with-random-32-byte-string"
JWT_ISSUER="pharmax-dev"
JWT_AUDIENCE="pharmax-dev"

# ----- Encryption / KMS ---------------------------------------------
# Master seed for the dev LocalKmsAdapter. apps/web and apps/worker
# MUST agree on this value or rows encrypted by one process are
# undecryptable by the other. >=32 chars; use a high-entropy random
# string. Generate with: openssl rand -base64 48
PHARMAX_LOCAL_KMS_SEED="replace-with-random-48-byte-base64-string-min-32-chars"

# Legacy placeholders (to be removed once AwsKmsAdapter lands).
# DO NOT use in new code — @pharmax/crypto handles all DEK/KEK
# material now via the configured KmsAdapter.
ENCRYPTION_KEY_PRIMARY=""
ENCRYPTION_KEY_PREVIOUS=""
SEARCH_TOKEN_KEY_PRIMARY=""
SEARCH_TOKEN_KEY_PREVIOUS=""

# AwsKmsAdapter (production envelope encryption) — leave blank in
# local dev. apps/web and apps/worker hard-fail boot under
# NODE_ENV=production when any of AWS_REGION, AWS_KMS_DATA_KEY_ID,
# or AWS_KMS_SEARCH_KEY_ID is unset (see
# apps/web/src/server/bootstrap.ts → buildKmsAdapter).
#
#   - AWS_KMS_DATA_KEY_ID   ENCRYPT_DECRYPT / SYMMETRIC_DEFAULT
#                           CMK. Accepts ARN, key id, or alias.
#   - AWS_KMS_SEARCH_KEY_ID GENERATE_VERIFY_MAC / HMAC_256 CMK.
#                           Accepts ARN, key id, or alias.
#   - AWS_KMS_KEY_LABEL     Optional short stable label embedded
#                           in the kid we persist with each
#                           envelope. Defaults to "app-phi".
#                           Changing this AFTER PHI is encrypted
#                           breaks decrypt for existing rows.
#
# Run scripts/security/verify-kms-keys.ts (pnpm verify:kms) after
# a deploy to confirm IAM + key health.
# AWS_KMS_DATA_KEY_ID="alias/pharmax/app-phi-key"
# AWS_KMS_SEARCH_KEY_ID="alias/pharmax/search-key"
# AWS_KMS_KEY_LABEL="app-phi"

# ----- Worker (apps/worker) -----------------------------------------
# Same DATABASE_URL / PHARMAX_LOCAL_KMS_SEED as apps/web.

# ----- Print agent (apps/print-agent) -------------------------------
# Polls SENT vial print jobs for a paired workstation and confirms
# completion via ConfirmVialLabelPrint. Uses file mode locally.
PRINT_AGENT_ORG_SLUG="acme"
PRINT_AGENT_WORKSTATION_CODE="WS-01"
PRINT_AGENT_ACTOR_EMAIL="print-agent@acme.test"
PRINT_AGENT_POLL_INTERVAL_MS="2000"
PRINT_AGENT_SHUTDOWN_TIMEOUT_MS="15000"
PRINT_AGENT_ZPL_MODE="file"
PRINT_AGENT_ZPL_FILE_PATH="/tmp/pharmax-vial-label.zpl"
PRINT_AGENT_PRINTER_HOST="127.0.0.1"
PRINT_AGENT_PRINTER_PORT="9100"
PRINT_AGENT_PRINTER_TIMEOUT_MS="10000"

# ----- External APIs (leave blank locally) --------------------------
EASYPOST_API_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ----- Error tracking (Sentry) --------------------------------------
# When SENTRY_DSN is unset (default in local dev), every Sentry SDK
# no-ops and `Logger.error` only writes to stdout. In staging and
# prod these MUST be set; the bootstrap layer warns on a prod boot
# without them.
#
# - SENTRY_DSN: the server-side DSN. Different from NEXT_PUBLIC_SENTRY_DSN.
# - NEXT_PUBLIC_SENTRY_DSN: the browser DSN. Visible to clients (by design).
# - SENTRY_ENVIRONMENT: "development" | "staging" | "production".
# - SENTRY_RELEASE: usually the git SHA — wired from CI at deploy time.
# - SENTRY_AUTH_TOKEN: build-time only, for source-map upload. NOT
#   needed at runtime. Use a project-scoped token with minimum
#   `project:releases` scope.
# - SENTRY_ORG / SENTRY_PROJECT: build-time only, for source-map upload.
# - SENTRY_TRACES_SAMPLE_RATE / SENTRY_PROFILES_SAMPLE_RATE: 0..1.
#   Start at 0 (off) and ramp once baseline is understood.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT=""
SENTRY_RELEASE=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_TRACES_SAMPLE_RATE="0"
SENTRY_PROFILES_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"

# ----- AWS (production only; leave blank locally) -------------------
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
