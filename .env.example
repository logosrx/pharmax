# =====================================================================
# Pharmax local environment template.
# Copy to .env (gitignored) and fill in any blank values.
# Never put real PHI, real customer keys, or production secrets here.
# =====================================================================

# ----- Application ---------------------------------------------------
NODE_ENV="development"
APP_NAME="Pharmax"
APP_URL="http://localhost:3000"
PORT="3000"
LOG_LEVEL="debug"

# ----- Database ------------------------------------------------------
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="pharmax"
# Local dev connects as the `postgres` superuser (BYPASSRLS), so RLS is
# inert locally — tenant isolation is still enforced by the ORM tenancy
# extension (fail-closed). This is intentional for a frictionless dev DB.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pharmax"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pharmax"

# --- Production database roles (RLS cutover) -------------------------
# The RLS baseline migration (20260522060000_rls_baseline) provisions
# two NOLOGIN roles. Production gives each runtime SERVICE a distinct
# session role via the libpq `options=-c role=...` startup parameter
# (Prisma forwards `options` since 3.8.0). Migrations keep running as
# the owner/superuser via DIRECT_URL.
#
#   apps/web  -> pharmax_app    (RLS-SUBJECT; the untrusted request
#               surface). Every tenant read/write sets the per-tx
#               `organization_id` GUC (command bus + readInOrgScope /
#               readInTenantContext) and every cross-org system read
#               sets the `system_context` GUC (readInSystemContext +
#               the auth/webhook resolvers). RLS is the DB-layer
#               backstop to the ORM extension.
#
#   apps/worker -> pharmax_system  (BYPASSRLS supervisor). The worker
#               is cross-org by construction (outbox drain, webhook
#               resolution, schedulers, merkle/access-review sweeps),
#               so it uses the BYPASSRLS role the baseline reserves for
#               "multiple orgs touched in one operation". Per-tenant
#               work the worker performs still goes through the ORM
#               extension + command bus; `audit_log` UPDATE/DELETE is
#               revoked from pharmax_system too, so immutability holds.
#
# Example production values (set per-service; grant role membership to
# the login first, e.g. `GRANT pharmax_app TO <login>`):
#   apps/web   DATABASE_URL="postgresql://<login>:<pw>@<host>:5432/pharmax?options=-c%20role%3Dpharmax_app"
#   apps/worker DATABASE_URL="postgresql://<login>:<pw>@<host>:5432/pharmax?options=-c%20role%3Dpharmax_system"
#   (both)     DIRECT_URL="postgresql://<owner>:<pw>@<host>:5432/pharmax"
#
# Do NOT flip these until the cutover is validated end-to-end against a
# live database (login -> tenant read -> command -> system command ->
# worker tick). See docs/RUNBOOK.md "RLS role cutover".

# --- Connection pool tuning (PRODUCTION) ----------------------------
# Prisma defaults the pool to (num_physical_cpus * 2 + 1) per process,
# which is tiny on a 1-2 vCPU container. Because every tenant read/write
# runs inside an INTERACTIVE transaction (BEGIN -> set GUC -> query(s)
# -> COMMIT), a connection is held for the whole tx window, not just the
# query. Under concurrent operators that exhausts the pool and requests
# block (Prisma `P2024: Timed out fetching a connection`).
#
# Size each service's pool EXPLICITLY against Postgres `max_connections`,
# leaving headroom for migrations (DIRECT_URL), psql, and the worker:
#
#   sum(per-instance connection_limit * instance_count) across web +
#   worker  <  max_connections - reserved_superuser_connections
#
# Append as query params to DATABASE_URL (NOT DIRECT_URL — migrations
# want a single connection):
#
#   ...&connection_limit=10&pool_timeout=10
#
#   connection_limit  pool size per process. Start ~10 for web, lower
#                     (~5) for the worker (its drains are batch/poll, not
#                     latency-critical). Tune from observed `P2024` rates
#                     + DB `max_connections`.
#   pool_timeout      seconds to wait for a free connection before
#                     throwing P2024 (default 10). Keep small so a
#                     saturated pool fails fast + sheds load instead of
#                     piling up request latency.
#
# At enterprise scale, front Postgres with a TRANSACTION-MODE pooler
# (AWS RDS Proxy or PgBouncer) and point DATABASE_URL at it. The RLS
# GUCs use `set_config(..., is_local := true)` (transaction-scoped), so
# they are SAFE under transaction pooling. When using PgBouncer in
# transaction mode, also append `&pgbouncer=true` so Prisma disables
# prepared-statement caching that transaction pooling cannot preserve.
#
# Example:
#   apps/web   DATABASE_URL="postgresql://<login>:<pw>@<proxy-host>:5432/pharmax?options=-c%20role%3Dpharmax_app&connection_limit=10&pool_timeout=10"
#   apps/worker DATABASE_URL="postgresql://<login>:<pw>@<proxy-host>:5432/pharmax?options=-c%20role%3Dpharmax_system&connection_limit=5&pool_timeout=10"

# ----- Redis / Valkey ------------------------------------------------
REDIS_URL="redis://localhost:6379"

# ----- Object storage (MinIO in dev, S3 in prod) ---------------------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET_NAME="pharmax-dev"
S3_FORCE_PATH_STYLE="true"
S3_ACCESS_KEY_ID="pharmax_minio"
S3_SECRET_ACCESS_KEY="pharmax_minio_dev"
MINIO_ROOT_USER="pharmax_minio"
MINIO_ROOT_PASSWORD="pharmax_minio_dev"

# ----- Mail (Mailhog in dev) -----------------------------------------
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Pharmax <no-reply@pharmax.local>"

# ----- PgAdmin -------------------------------------------------------
PGADMIN_EMAIL="admin@pharmax.local"
PGADMIN_PASSWORD="pharmax_dev"

# ----- Sessions / Auth ----------------------------------------------
# Generate with: openssl rand -base64 48
SESSION_SECRET="replace-with-random-48-byte-base64-string"
JWT_SECRET="replace-with-random-32-byte-string"
JWT_ISSUER="pharmax-dev"
JWT_AUDIENCE="pharmax-dev"

# ----- Encryption / KMS ---------------------------------------------
# Master seed for the dev LocalKmsAdapter. apps/web and apps/worker
# MUST agree on this value or rows encrypted by one process are
# undecryptable by the other. >=32 chars; use a high-entropy random
# string. Generate with: openssl rand -base64 48
PHARMAX_LOCAL_KMS_SEED="replace-with-random-48-byte-base64-string-min-32-chars"

# Legacy placeholders (to be removed once AwsKmsAdapter lands).
# DO NOT use in new code — @pharmax/crypto handles all DEK/KEK
# material now via the configured KmsAdapter.
ENCRYPTION_KEY_PRIMARY=""
ENCRYPTION_KEY_PREVIOUS=""
SEARCH_TOKEN_KEY_PRIMARY=""
SEARCH_TOKEN_KEY_PREVIOUS=""

# AwsKmsAdapter (production envelope encryption) — leave blank in
# local dev. apps/web and apps/worker hard-fail boot under
# NODE_ENV=production when any of AWS_REGION, AWS_KMS_DATA_KEY_ID,
# or AWS_KMS_SEARCH_KEY_ID is unset (see
# apps/web/src/server/bootstrap.ts → buildKmsAdapter).
#
#   - AWS_KMS_DATA_KEY_ID   ENCRYPT_DECRYPT / SYMMETRIC_DEFAULT
#                           CMK. Accepts ARN, key id, or alias.
#   - AWS_KMS_SEARCH_KEY_ID GENERATE_VERIFY_MAC / HMAC_256 CMK.
#                           Accepts ARN, key id, or alias.
#   - AWS_KMS_KEY_LABEL     Optional short stable label embedded
#                           in the kid we persist with each
#                           envelope. Defaults to "app-phi".
#                           Changing this AFTER PHI is encrypted
#                           breaks decrypt for existing rows.
#   - AWS_KMS_PREVIOUS_DATA_KEY_IDS
#                           Comma-separated list of historical
#                           ENCRYPT_DECRYPT CMK ARNs/aliases used
#                           during a manual CMK identity rotation
#                           bake-in window. Steady state: leave
#                           unset (zero behavioral change). During
#                           rotation: list the OLD CMK(s) here so
#                           historical envelopes still decrypt
#                           after the alias swap. apps/web and
#                           apps/worker MUST agree on this value
#                           for the duration of the rotation. See
#                           docs/RUNBOOK.md § "Rotating a KMS data
#                           key — Manual CMK rotation".
#
# Run scripts/security/verify-kms-keys.ts (pnpm verify:kms) after
# a deploy to confirm IAM + key health.
# AWS_KMS_DATA_KEY_ID="alias/pharmax/app-phi-key"
# AWS_KMS_SEARCH_KEY_ID="alias/pharmax/search-key"
# AWS_KMS_KEY_LABEL="app-phi"
# AWS_KMS_PREVIOUS_DATA_KEY_IDS="alias/pharmax/app-phi-key-v1"

# ----- Worker (apps/worker) -----------------------------------------
# Same DATABASE_URL / PHARMAX_LOCAL_KMS_SEED as apps/web.

# ----- Print agent (apps/print-agent) -------------------------------
# Polls SENT vial print jobs for a paired workstation and confirms
# completion via ConfirmVialLabelPrint. Uses file mode locally.
PRINT_AGENT_ORG_SLUG="acme"
PRINT_AGENT_WORKSTATION_CODE="WS-01"
PRINT_AGENT_ACTOR_EMAIL="print-agent@acme.test"
PRINT_AGENT_POLL_INTERVAL_MS="2000"
PRINT_AGENT_SHUTDOWN_TIMEOUT_MS="15000"
PRINT_AGENT_ZPL_MODE="file"
PRINT_AGENT_ZPL_FILE_PATH="/tmp/pharmax-vial-label.zpl"
PRINT_AGENT_PRINTER_HOST="127.0.0.1"
PRINT_AGENT_PRINTER_PORT="9100"
PRINT_AGENT_PRINTER_TIMEOUT_MS="10000"

# ----- External APIs (leave blank locally) --------------------------
EASYPOST_API_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ----- Error tracking (Sentry) --------------------------------------
# When SENTRY_DSN is unset (default in local dev), every Sentry SDK
# no-ops and `Logger.error` only writes to stdout. In staging and
# prod these MUST be set; the bootstrap layer warns on a prod boot
# without them.
#
# - SENTRY_DSN: the server-side DSN. Different from NEXT_PUBLIC_SENTRY_DSN.
# - NEXT_PUBLIC_SENTRY_DSN: the browser DSN. Visible to clients (by design).
# - SENTRY_ENVIRONMENT: "development" | "staging" | "production".
# - SENTRY_RELEASE: usually the git SHA — wired from CI at deploy time.
# - SENTRY_AUTH_TOKEN: build-time only, for source-map upload. NOT
#   needed at runtime. Use a project-scoped token with minimum
#   `project:releases` scope.
# - SENTRY_ORG / SENTRY_PROJECT: build-time only, for source-map upload.
# - SENTRY_TRACES_SAMPLE_RATE / SENTRY_PROFILES_SAMPLE_RATE: 0..1.
#   Start at 0 (off) and ramp once baseline is understood.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT=""
SENTRY_RELEASE=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_TRACES_SAMPLE_RATE="0"
SENTRY_PROFILES_SAMPLE_RATE="0"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0"

# ----- AWS (production only; leave blank locally) -------------------
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
