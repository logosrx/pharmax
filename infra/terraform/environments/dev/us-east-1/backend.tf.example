# =============================================================================
# Pharmax — dev / us-east-1 backend.
#
# COPY THIS FILE TO `backend.tf` (gitignored). Substitute the placeholders
# (REPLACE_*) with the values produced by the `infra/terraform/bootstrap/`
# Terraform run for this AWS account / env.
#
# Why a separate state per env-region:
#   - Concurrency: a `terraform apply` against prod-use1 must not block a
#     `terraform plan` against dev-use1.
#   - Blast radius: state corruption in one env-region cannot cascade.
#   - Compliance: prod state is in a more locked-down bucket; dev state is
#     in a permissive bucket. Same primitive, different policy.
# =============================================================================

terraform {
  backend "s3" {
    bucket         = "REPLACE_pharmax-tfstate-dev-<account-suffix>"
    key            = "pharmax/dev/us-east-1/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "REPLACE_pharmax-tfstate-locks-dev"
    encrypt        = true
    kms_key_id     = "REPLACE_arn:aws:kms:us-east-1:<account>:key/<state-cmk-id>"
  }
}
